# Database configuration
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/recruitai

# JWT Authentication
JWT_SECRET_KEY=generate_a_secure_long_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis configuration for Celery background tasks
REDIS_URL=redis://localhost:6379/0

# AWS S3 Configurations
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=recruitai-resumes
S3_BUCKET_NAME=recruitai-resumes

# AI Layer Integration (LLM & Embeddings)
LLM_PROVIDER=gemini  # Options: gemini, openai
GEMINI_MODEL=gemini-1.5-flash  # e.g. gemini-1.5-flash or gemini-1.5-pro
EMBEDDING_PROVIDER=gemini  # Options: gemini, openai
EMBEDDING_MODEL=text-embedding-004  # Options: text-embedding-004, text-embedding-3-small
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Storage Mode (local or s3)
STORAGE_MODE=local

# Local development job running (true = run synchronously in-process without celery worker)
RUN_JOBS_SYNC=false

# Qdrant Vector DB
QDRANT_ENABLED=false
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=candidates_vectors

# Matching Engine top-N candidates to score
MATCHING_TOP_N=20

# Celery Configurations (optional; defaults to REDIS_URL if using Redis, else database fallback)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
